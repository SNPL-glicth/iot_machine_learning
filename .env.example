# ═══════════════════════════════════════════
# ZENIN ML — Variables de entorno
# Copiar a .env y completar valores reales
# NUNCA commitear .env con valores reales
# ═══════════════════════════════════════════

# Base de datos principal (SQL Server)
ZENIN_DB_HOST=localhost
ZENIN_DB_PORT=1433
ZENIN_DB_NAME=zenin_db
ZENIN_DB_USER=sa
ZENIN_DB_PASSWORD=change_me

# Redis (cache)
REDIS_URL=redis://localhost:6379/0

# MQTT (mensajería IoT)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ML
ML_ENV=development        # development | staging | production
ML_LOG_LEVEL=INFO
ML_ANALYSIS_TIMEOUT=30    # segundos
ML_MAX_WORKERS=4

# Weaviate (memoria semántica — activar en T10)
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=

# RabbitMQ (mensajería avanzada — activar en T11)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
