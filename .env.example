# ============================================================================
# IOT MACHINE LEARNING - ENVIRONMENT VARIABLES
# ============================================================================

# ============================================================================
# POSTGRESQL RAILWAY (ML Predictions & Models Database)
# ============================================================================


# Connection URL format for SQLAlchemy
DATABASE_URL=postgresql://postgres:urVeKdORRUEwwrrFYHSwKfnsQzRFhyxU@crossover.proxy.rlwy.net:22152/railway
POSTGRES_URL=postgresql://postgres:urVeKdORRUEwwrrFYHSwKfnsQzRFhyxU@crossover.proxy.rlwy.net:22152/railway

# ============================================================================
# REDIS (Broker, Cache)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ============================================================================
# ML API CONFIGURATION
# ============================================================================
ML_API_PORT=8002
ML_API_HOST=0.0.0.0
ML_API_WORKERS=2

# ============================================================================
# ML ENGINE CONFIGURATION
# ============================================================================
ML_DEFAULT_ENGINE=taylor
ML_ROLLBACK_TO_BASELINE=false
ML_ENGINE_TAYLOR_ENABLED=true
ML_ENGINE_STATISTICAL_ENABLED=true
ML_ENGINE_COGNITIVE_ENABLED=true

# Taylor Engine
TAYLOR_ORDER=2
TAYLOR_DERIVATIVE_METHOD=backward
TAYLOR_TREND_THRESHOLD=0.1
TAYLOR_MIN_CONFIDENCE=0.3
TAYLOR_MAX_CONFIDENCE=0.95

# Statistical Engine
STATISTICAL_ALPHA=0.3
STATISTICAL_BETA=0.1

# ============================================================================
# ANOMALY DETECTION
# ============================================================================
ANOMALY_ENABLED=true
ANOMALY_THRESHOLD=0.7
ANOMALY_MIN_TRAINING_POINTS=20

# Voting weights
ANOMALY_WEIGHT_IF=0.30
ANOMALY_WEIGHT_ZSCORE=0.20
ANOMALY_WEIGHT_VELOCITY_Z=0.15
ANOMALY_WEIGHT_LOF=0.15
ANOMALY_WEIGHT_IQR=0.10
ANOMALY_WEIGHT_ACCEL_Z=0.10

# ============================================================================
# PATTERN DETECTION
# ============================================================================
PATTERN_DETECTION_ENABLED=true
DELTA_SPIKE_THRESHOLD=0.10
CHANGE_POINT_THRESHOLD=5.0

# ============================================================================
# COGNITIVE ORCHESTRATOR
# ============================================================================
COGNITIVE_ENABLED=false
COGNITIVE_PLASTICITY_ENABLED=true
COGNITIVE_INHIBITION_ENABLED=true
COGNITIVE_MIN_ENGINES=2

# ============================================================================
# WEAVIATE (Memoria Cognitiva - Opcional)
# ============================================================================
WEAVIATE_URL=http://localhost:8080
WEAVIATE_ENABLED=false
WEAVIATE_API_KEY=

# ============================================================================
# BATCH RUNNER
# ============================================================================
BATCH_ENABLED=true
BATCH_INTERVAL_SECONDS=300
BATCH_WINDOW_SIZE=50
BATCH_MAX_SENSORS=1000

# ============================================================================
# STREAM RUNNER
# ============================================================================
STREAM_ENABLED=true
STREAM_CONSUMER_GROUP=ml_stream_consumer
STREAM_WINDOW_1S=10
STREAM_WINDOW_5S=50
STREAM_WINDOW_10S=100

# ============================================================================
# METRICS & MONITORING
# ============================================================================
METRICS_ENABLED=true
METRICS_EXPORT_INTERVAL=60
AB_TESTING_ENABLED=false

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

DB_DIALECT=mssql
DB_HOST=localhost
DB_PORT=1434
DB_USER=sa
DB_PASSWORD=Sandevistan2510
DB_NAME=iot_monitoring_system
