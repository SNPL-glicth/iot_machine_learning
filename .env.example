# ════════════════════════════════════════════════════════════════════
# ZENIN ML — Variables de entorno
# Copiar a .env y completar valores reales
# NUNCA commitear .env con valores reales
# ════════════════════════════════════════════════════════════════════

# ─── Base de datos (REQUERIDAS en producción) ─────────────────────
ZENIN_DB_HOST=localhost
ZENIN_DB_PORT=1434
ZENIN_DB_NAME=zenin_db
ZENIN_DB_USER=sa
# REQUERIDA sin default seguro. Debe ser sobreescrita en producción.
ZENIN_DB_PASSWORD=REQUIRED_NO_DEFAULT

# ─── Redis (REQUERIDA en producción con Docker Compose) ────────────
REDIS_URL=redis://localhost:6379/0

# ─── MQTT (mensajería IoT — opcional) ──────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── Broker type (opcional) ────────────────────────────────────────
# BROKER_TYPE=

# ─── ML / Entorno (opcionales, defaults seguros) ──────────────────
ML_ENV=development        # development | staging | production
ML_LOG_LEVEL=INFO
ML_ANALYSIS_TIMEOUT=30    # segundos
ML_MAX_WORKERS=4

# ─── Compliance Export (opcional) ─────────────────────────────────
# Si se define, debe estar bajo ML_COMPLIANCE_BASE_DIR (path traversal validado)
# ML_COMPLIANCE_EXPORT_PATH=/var/lib/zenin/compliance/exports.jsonl
ML_COMPLIANCE_BASE_DIR=/var/lib/zenin/compliance

# ─── HMAC Key para integridad de compliance (opcional) ────────────
# ML_COMPLIANCE_HMAC_KEY=
# ML_COMPLIANCE_HMAC_KEY_V2=
# ML_COMPLIANCE_HMAC_KEY_VERSION=
# ML_HMAC_KEY_CREATED_AT=

# ─── AI Explainer (opcional) ──────────────────────────────────────
# AI_EXPLAINER_URL=

# ─── Weaviate (memoria semántica — activar en T10) ─────────────────
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_ENABLED=false
# WEAVIATE_API_KEY=
ML_COGNITIVE_MEMORY_URL=http://localhost:8080
ML_ENABLE_COGNITIVE_MEMORY=false  # true para activar Weaviate

# ─── RabbitMQ (mensajería avanzada — activar en T11) ──────────────
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ─── Feature Flags (todos opcionales, defaults en código) ───────
# ML_ROLLBACK_TO_BASELINE=false
# ML_USE_TAYLOR_PREDICTOR=false
# ML_USE_KALMAN_FILTER=false
# ML_TAYLOR_ORDER=1
# ML_TAYLOR_HORIZON=1
# ML_KALMAN_Q=0.01
# ML_KALMAN_WARMUP_SIZE=10
# ML_ENABLE_AB_TESTING=false
# ML_TAYLOR_SENSOR_WHITELIST=
# ML_DEFAULT_ENGINE=
# ML_BATCH_USE_ENTERPRISE=false
# ML_BATCH_ENTERPRISE_SENSORS=
# ML_BATCH_BASELINE_ONLY_SENSORS=

# ─── Cognitive Orchestrator (Batch Runner) ──────────────────────────
# Activar MetaCognitiveOrchestrator en batch runner.
# Requiere Redis activo para plasticidad bayesiana.
# Default false — activar primero en staging.
# ML_USE_COGNITIVE_ORCHESTRATOR=false

# Timeout global del orchestrador en segundos.
# Si supera este límite, hace fallback a baseline.
# ML_ORCHESTRATOR_TIMEOUT_S=5.0

# ─── Window / Queue (opcionales) ──────────────────────────────────
# ML_WINDOW_MAX_AGE_SECONDS=
# ML_WINDOW_TTL_SECONDS=
# ZENIN_QUEUE_POLLER_ENABLED=false
# ZENIN_QUEUE_BATCH_SIZE=
# ZENIN_QUEUE_POLL_INTERVAL_SECONDS=

# ─── Cooldown Setup ────────────────────────────────────────────────
# Cooldown por defecto para predicciones de sensores (segundos)
# DEFAULT_PREDICTION_INTERVAL_SECONDS=30
