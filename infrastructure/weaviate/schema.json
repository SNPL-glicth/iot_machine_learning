{
  "classes": [
    {
      "class": "SensorProfile",
      "description": "Equipment-aware sensor calibration profile. Defines operational ranges and noise characteristics.",
      "vectorizer": "text2vec-transformers",
      "moduleConfig": {
        "text2vec-transformers": {
          "vectorizeClassName": true
        }
      },
      "properties": [
        {
          "name": "seriesId",
          "dataType": ["text"],
          "description": "UTSAE canonical series identifier",
          "moduleConfig": {
            "text2vec-transformers": {"skip": true, "vectorizePropertyName": false}
          }
        },
        {
          "name": "equipmentClass",
          "dataType": ["text"],
          "description": "Type of equipment: hvac, motor, pump, turbine, etc.",
          "moduleConfig": {
            "text2vec-transformers": {"skip": false, "vectorizePropertyName": false}
          }
        },
        {
          "name": "operationalRangeMin",
          "dataType": ["number"],
          "description": "Minimum expected sensor value"
        },
        {
          "name": "operationalRangeMax",
          "dataType": ["number"],
          "description": "Maximum expected sensor value"
        },
        {
          "name": "setpointTolerance",
          "dataType": ["number"],
          "description": "Allowed deviation from setpoint"
        },
        {
          "name": "noiseFloor",
          "dataType": ["number"],
          "description": "Minimum significant signal amplitude"
        },
        {
          "name": "hampelK",
          "dataType": ["number"],
          "description": "Hampel filter K parameter (default 3.0)"
        },
        {
          "name": "hampelWindow",
          "dataType": ["int"],
          "description": "Hampel filter window size (default 10)"
        },
        {
          "name": "typicalCycleDurationSeconds",
          "dataType": ["int"],
          "description": "Expected operational cycle duration if cyclical"
