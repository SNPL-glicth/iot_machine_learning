        {
          "name": "thermalInertiaClass",
          "dataType": ["text"],
          "description": "Thermal response speed: fast, medium, slow",
          "moduleConfig": {
            "text2vec-transformers": {"skip": true, "vectorizePropertyName": false}
          }
        },
        {
          "name": "maintenanceHistoryScore",
          "dataType": ["number"],
          "description": "0.0-1.0 score indicating maintenance health"
        },
        {
          "name": "sensorType",
          "dataType": ["text"],
          "description": "Sensor measurement type: temperature, humidity, pressure, etc.",
          "moduleConfig": {
            "text2vec-transformers": {"skip": false, "vectorizePropertyName": false}
          }
        },
        {
          "name": "unit",
